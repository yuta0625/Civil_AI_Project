        law:PriceAdjustment,
        law:Procedure,
        law:Suspension,
        law:TimeExtension ;
    law:sourceFile "第２部　逐条解説　第２０条 .md" ;
    law:summary "#### (工事の中止)  - 20条工事用地等の確保ができない等のため又は暴風、豪雨、洪水、高潮、地 震、地すべり、落盤、火災、騒乱、暴動その他の自然的又は人為的な事象(以 下「天災等」という。)であって受注者の責めに帰すことができないものにより 工事目的物等に損害を生じ若しくは工事現場の状態が変動したため、受注者が 工事を施工できないと認められるときは、発注者は、工事の中止内容を直ちに 受注者..." .

law:Article_22 a law:TreatiseElement ;
    rdfs:label "第22条" ;
    law:refersTo law:Article_1,
        law:Article_18,
        law:Article_2,
        law:Article_24,
        law:Article_44,
        law:Article_55 ;
    law:relatesTo law:Damages,
