
# === LLM設定 ===
LLM_MODEL=qwen2.5:7b
EMBEDDING_MODEL=nomic-embed-text

# === Ollama接続 ===
# Mac環境の場合
OLLAMA_BASE_URL=http://host.docker.internal:11434
# WSL2環境の場合はこちらをコメントアウト解除、上をコメントアウト
# OLLAMA_BASE_URL=http://ollama:11434

# === Fuseki（知識グラフDB）===
FUSEKI_URL=http://fuseki:3030/ConstructionLaw/query
FUSEKI_ADMIN_PASSWORD=your_fuseki_password

# === Neo4j（グラフDB）===
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# === Paths（コンテナ内パス）===
VECTORSTORE_PATH=/app/data/vectorstore
DOCS_PATH=/app/data/markdown_docs

# === API Server ===
API_PORT=8080
